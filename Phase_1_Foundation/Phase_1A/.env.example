# Google AI Studio (Gemini) - Primary LLM
# Get it at: https://aistudio.google.com/
GOOGLE_API_KEY=key

# Groq - Fallback LLM / Fast Inference
# Get it at: https://console.groq.com/
GROQ_API_KEY=key

# Tavily - Search Tool
# Get it at: https://tavily.com/
TAVILY_API_KEY=key
TAVILY_API_KEY_SECONDARY=your_tavily_api_key_2_here

# Optional: LangSmith for tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key_here
